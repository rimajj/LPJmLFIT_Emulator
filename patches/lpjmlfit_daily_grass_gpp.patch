diff --git a/src/lpj/daily_natural.c b/src/lpj/daily_natural.c
index 91bc578..6eb2340 100644
--- a/src/lpj/daily_natural.c
+++ b/src/lpj/daily_natural.c
@@ -216,6 +216,14 @@ Real daily_natural(Patch *patch,                /**< [inout] patch pointer */
     stand->cell->balance.agpp+=gpp*frac;
     getoutput(output,NPP,config)+=npp*frac;
     getoutput(output,GPP,config)+=gpp*frac;
+    /* grass-only daily GPP/NPP (F_diff grass-level validation) — accumulated UNCONDITIONALLY like the
+       GPP/NPP outputs above (cell-mean, *frac), so a daily-timestep request yields the cell-mean daily
+       grass flux directly comparable to the (GPP,daily) output. Grass = natural PFT type GRASS. */
+    if(getpftpar(pft,type)==GRASS)
+    {
+      getoutput(output,D_GRASS_NPP,config)+=npp*frac;
+      getoutput(output,D_GRASS_GPP,config)+=gpp*frac;
+    }
     getoutput(output,FAPAR,config) += pft->fapar * frac * (1.0/(1-stand->cell->lakefrac-stand->cell->ml.reservoirfrac));
     if (stand->type->landusetype == SETASIDE_RF || stand->type->landusetype == SETASIDE_IR)
       getoutput(output,NPP_AGR,config) += npp*frac / agrfrac;
diff --git a/src/lpj/fwriteoutput.c b/src/lpj/fwriteoutput.c
index b017ccd..7b96222 100644
--- a/src/lpj/fwriteoutput.c
+++ b/src/lpj/fwriteoutput.c
@@ -2114,5 +2114,10 @@ void fwriteoutput(Outputfile *output,  /**< output file array */
   }
   for(i=D_LAI;i<=D_PET;i++)
     writeoutputvar(i,1);
+  /* daily grass GPP/NPP (F_diff grass-level validation) — new scalar daily outputs whose ids lie
+     OUTSIDE the D_LAI..D_PET daily range, so they are flushed explicitly here (iswrite gates them to
+     the DAILY timestep + open file). */
+  writeoutputvar(D_GRASS_GPP,1);
+  writeoutputvar(D_GRASS_NPP,1);
   free(vec);
 } /* of 'fwriteoutput' */
