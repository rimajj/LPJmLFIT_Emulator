# ── Secrets / credentials (NEVER commit) ─────────────────────────────────────
*.pem
*.key
*_deploy
*_signing
id_ed25519*
id_rsa*
.env
.env.*
secrets/
*token*
*credential*

# ── Data, model weights, large binaries (tracked via DVC pointers, not git) ──
# LPJmL inputs/outputs & restarts live on /p/projects and /p/tmp, never in-repo.
*.clm
*.lpj
*.nc
*.nc4
*.bin
*.soil.bin
*.parquet
*.arrow
*.feather
*.h5
*.hdf5
data/raw/
data/interim/
data/processed/
artifacts/models/
artifacts/logs/
!**/.gitkeep

# ── Julia ────────────────────────────────────────────────────────────────────
# Manifest.toml SHOULD be committed for reproducibility (ENGINEERING_STANDARDS §7) once the
# package has real dependencies. Until then [deps] is empty, so the auto-generated root
# Manifest is trivial and only records the Julia patch version (pure churn) — ignore it for now
# and UN-IGNORE (delete this line) + commit it when Phase-3 deps (Enzyme/Lux/SciML) are added.
/Manifest.toml
# docs/Manifest.toml is a local artifact of `Pkg.instantiate()` on the docs env; the docs CI
# resolves fresh each build, so keep it out of git (same rationale as the root Manifest).
/docs/Manifest.toml
*.jl.cov
*.jl.*.cov
*.jl.mem
/docs/build/
/docs/site/
LocalPreferences.toml
deps/deps.jl
.julia_history

# ── Documentation build ──────────────────────────────────────────────────────
docs/build/
docs/src/generated/*.svg
_freeze/
.quarto/
*_files/

# ── Python (slow-emulator prototype) ─────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# ── Experiment tracking / provenance ─────────────────────────────────────────
mlruns/
mlartifacts/
.dvc/cache/
.dvc/tmp/

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
*.swp
*~
core-*
